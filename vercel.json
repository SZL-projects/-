{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    { "source": "/api/auth/:path*", "destination": "/api/auth" },
    { "source": "/api/vehicles/:path*", "destination": "/api/vehicles" },
    { "source": "/api/users/:path*", "destination": "/api/users" },
    { "source": "/api/riders/:path*", "destination": "/api/riders" },
    { "source": "/api/tasks/:path*", "destination": "/api/tasks" },
    { "source": "/api/monthly-checks/:path*", "destination": "/api/monthly-checks" },
    { "source": "/api/faults/:path*", "destination": "/api/faults" },
    { "source": "/api/drive/:path*", "destination": "/api/drive" },
    { "source": "/api/maintenance/:path*", "destination": "/api/maintenance" },
    { "source": "/api/garages/:path*", "destination": "/api/maintenance" },
    { "source": "/api/maintenance-types/:path*", "destination": "/api/maintenance" },
    { "source": "/api/permissions/:path*", "destination": "/api/permissions" },
    { "source": "/api/search/:path*", "destination": "/api/search" },
    { "source": "/api/reports/:path*", "destination": "/api/reports" },
    { "source": "/api/audit-logs/:path*", "destination": "/api/reports" },
    { "source": "/api/donations/:path*", "destination": "/api/donations" },
    { "source": "/api/notifications/:path*", "destination": "/api/reports" }
  ],
  "crons": [
    {
      "path": "/api/reports/cron-reminders",
      "schedule": "30 16 * * *"
    }
  ]
}
